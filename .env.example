# DATABASE_URL: PostgreSQL database connection string for Supabase or external DB.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@your-db-subdomain.supabase.co:5432/postgres"

# Supabase Web Client Config: Required for Supabase Auth and User session handling.
VITE_SUPABASE_URL="https://your-supabase-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# ADMIN_SECRET_KEY: Password for the secure /sys-admin portal.
ADMIN_SECRET_KEY="super-secure-admin-pwd"
